datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model FranchiseLead {
  id                          String   @id
  fullName                    String
  fatherHusbandName           String
  dob                         String
  gender                      String
  aadhaarNumber               String   @unique
  panNumber                   String   @unique
  mobile                      String
  whatsApp                    String
  email                       String   @unique
  franchiseSelections         String[]
  currentOccupation           String
  existingBusinessName        String?
  businessExperience          Int
  educationSectorExperience   Int
  annualTurnover              String
  numberOfEmployees           Int
  buildingOwnership           String   // 'Own' | 'Lease' | 'Rent'
  totalArea                   Float
  numberOfClassrooms          Int
  computerLabAvailable        Boolean
  internetFacility            Boolean
  smartClassFacility          Boolean
  powerBackup                 Boolean
  buildingPhotos              String[]
  state                       String
  district                    String
  city                        String
  pincode                     String
  googleMapsLocation          String?
  populationCoverage          String   // 'Above 5 Lakhs' | '2 Lakhs - 5 Lakhs' | 'Below 2 Lakhs'
  nearbySchoolsColleges       String?
  competitorInstitutes        String?
  investmentCapacity          String   // '₹50,000 – ₹1 Lakh' | '₹1 Lakh – ₹3 Lakh' etc.
  courseCategories            String[]
  centreHeadName              String
  trainerCount                Int
  counselorCount              Int
  marketingExecutiveCount     Int
  aadhaarDoc                  String
  panDoc                      String
  educationalCertificates     String
  buildingAgreement           String
  gstCertificate              String?
  businessReg                 String?
  passportPhoto               String
  whyJoinRIEM                 String   @db.Text
  growthPlans                 String   @db.Text
  expectedAdmissionsFirstYear  Int
  expectedLaunchDate          String
  leadScore                   Int
  status                      String   @default("New") // 'New' | 'Under Review' | 'Approved' | 'Rejected' | 'On Hold'
  internalNotes               String?  @db.Text
  submittedAt                 DateTime @default(now())

  @@index([status])
  @@index([leadScore])
  @@index([state])
}
